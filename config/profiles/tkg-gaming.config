# tkg-gaming kernel config fragment
# Applied on top of defconfig for tkg gaming builds.
# Complements the linux-tkg patch stack (BORE, NTsync, Clear Linux).

# ── Scheduler ────────────────────────────────────────────────────────────────
CONFIG_HZ_1000=y
CONFIG_HZ=1000
CONFIG_PREEMPT=y
CONFIG_PREEMPT_VOLUNTARY=n

# ── CPU frequency ────────────────────────────────────────────────────────────
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y

# ── Memory ───────────────────────────────────────────────────────────────────
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS=y
CONFIG_ZSWAP=y
CONFIG_ZRAM=m
CONFIG_ZSMALLOC=y

# ── NTsync (Wine/Proton) ─────────────────────────────────────────────────────
# Requires 0007-*ntsync*.patch to be applied
CONFIG_NTSYNC=m

# ── Fsync / futex ────────────────────────────────────────────────────────────
CONFIG_FUTEX=y
CONFIG_FUTEX_PI=y

# ── IRQ / latency ────────────────────────────────────────────────────────────
CONFIG_IRQ_FORCED_THREADING=y
CONFIG_NO_HZ_FULL=n
CONFIG_NO_HZ_IDLE=y
CONFIG_HZ_PERIODIC=n

# ── GPU / graphics ───────────────────────────────────────────────────────────
CONFIG_DRM=y
CONFIG_DRM_AMDGPU=m
CONFIG_DRM_RADEON=m
CONFIG_DRM_I915=m
CONFIG_DRM_NOUVEAU=m

# ── Audio ────────────────────────────────────────────────────────────────────
CONFIG_SND=y
CONFIG_SND_HDA_INTEL=m
CONFIG_SND_USB_AUDIO=m

# ── USB / input ──────────────────────────────────────────────────────────────
CONFIG_USB_HID=y
CONFIG_HID_GENERIC=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_JOYSTICK=y
CONFIG_INPUT_JOYDEV=m

# ── Networking ───────────────────────────────────────────────────────────────
CONFIG_NET_SCH_FQ=y
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_TCP_CONG="bbr"

# ── Security ─────────────────────────────────────────────────────────────────
# Relax unprivileged user namespaces (required by many gaming tools/sandboxes)
CONFIG_USER_NS=y
